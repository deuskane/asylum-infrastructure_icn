name        : asylum:infrastructure:icn:1.3.2
description : Interconnection

#=========================================
filesets:
#=========================================

  #---------------------------------------
  hdl:
  #---------------------------------------
    files        :
      - hdl/icn_pkg.vhd
      - hdl/sbi_default_slave.vhd
      - hdl/sbi_pipe.vhd
      - hdl/sbi_icn_mux_mst.vhd
      - hdl/sbi_icn_mux_tgt.vhd
      - hdl/sbi_icn.vhd
      - hdl/sbi_wrapper_target.vhd
    file_type    : vhdlSource-2008
    logical_name : asylum
    depend       :
      - asylum:utils:pkg


  #---------------------------------------
  sim_basic:
  #---------------------------------------
    files        :
      - sim/tb_sbi_icn_pkg.vhd
      - sim/tb_sbi_icn_tc1_pkg.vhd
      - sim/tb_sbi_icn_tc2_pkg.vhd
      - sim/tb_sbi_icn_tc3_pkg.vhd
      - sim/tb_sbi_icn_suite_pkg.vhd
      - sim/tb_sbi_icn.vhd
    file_type    : vhdlSource-2008
    #logical_name : asylum
    depend       :
      - bitvis:verification:uvvm


#=========================================
targets:
#=========================================

  #---------------------------------------
  default: &default
  #---------------------------------------
    description     : Default Target
    filesets        :
      - hdl

  #---------------------------------------
  sim_basic:
  #---------------------------------------
    << : *default
    description     : Simulation of basic unit tests
    filesets_append :
      - sim_basic
    toplevel        : tb_sbi_icn
    default_tool    : ghdl
    tools :
      ghdl :
        analyze_options : ["-Wall","-fsynopsys","-frelaxed","--no-vital-checks"]
        run_options     : ["--fst=dut.fst","--ieee-asserts=disable"]
